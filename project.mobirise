              }
            },
            ".content-wrap": {
              "margin": "auto",
              "display": "flex",
              "height": "100%"
            },
            ".card-wrap": {
              "border-radius": "inherit",
              "height": "400px",
              "position": "relative",
              "transition": "all 0.3s",
              "margin-bottom": "2rem",
              "@media (max-width: 767px)": {
                "margin-bottom": "1rem"
              },
              "&:before": {
                "content": "\"\"",
                "position": "absolute",
                "border-radius": "inherit",
                "left": "0",
